---
import Layout from '../layouts/Layout.astro';
import QuoteForm from '../components/QuoteForm.astro';
import FAQSection from '../components/FAQSection.astro';

const phone = '555-555-5555';

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'LocalBusiness',
    name: 'Generator Gators',
    description: 'Generator Gators connects homeowners with vetted local standby generator installation partners across Long Island and New York City.',
    url: 'https://www.generatorgators.com',
    telephone: '555-555-5555',
    areaServed: [
      { '@type': 'City', name: 'Brooklyn', containedInPlace: { '@type': 'State', name: 'New York' } },
      { '@type': 'City', name: 'Queens', containedInPlace: { '@type': 'State', name: 'New York' } },
      { '@type': 'AdministrativeArea', name: 'Nassau County' },
      { '@type': 'AdministrativeArea', name: 'Suffolk County' },
    ],
    serviceType: 'Generator Installation Referral Service',
    logo: 'https://www.generatorgators.com/favicon.svg',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    serviceType: 'Whole Home Standby Generator Installation',
    provider: {
      '@type': 'LocalBusiness',
      name: 'Generator Gators',
    },
    areaServed: 'Long Island and New York City',
    description: 'Free generator installation quotes from vetted local professionals.',
  },
];
---

<Layout
  title="Generator Gators | Trusted Whole Home Generator Installation — Long Island & NYC"
  description="Generator Gators connects Long Island and NYC homeowners with vetted standby generator installers. Get a free whole home generator installation quote today."
  schema={schema}
>

  <!-- HERO -->
  <section class="bg-[#1a3a2a] text-white relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 lg:pt-28 pb-0">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-end">

        <!-- Left: Copy -->
        <div class="pb-20 lg:pb-28">
          <!-- Eyebrow -->
          <div class="inline-flex items-center gap-2 mb-7">
            <span class="w-5 h-[2px] bg-[#f5e642]"></span>
            <span class="text-[#f5e642] text-xs font-semibold tracking-widest uppercase">Long Island &amp; NYC</span>
          </div>

          <h1
            class="font-extrabold text-white mb-5"
            style="font-size:clamp(2.4rem,4.5vw,3.75rem); line-height:1.15; letter-spacing:-0.02em;"
          >
            Never Lose<br />
            <span style="color:#f5e642;">Power</span> Again.
          </h1>

          <p class="text-white/65 leading-relaxed mb-9" style="font-size:1.05rem; max-width:28rem;">
            We connect Long Island and NYC homeowners with vetted, licensed standby generator installers. Free matching. No obligation. Quote in 24 hours.
          </p>

          <div class="flex flex-col sm:flex-row gap-3 mb-8">
            <a
              href="#quote-form"
              class="inline-flex items-center justify-center gap-2 font-semibold text-sm px-7 py-3.5 rounded-[4px] transition-colors"
              style="background:#f5e642; color:#1a1a1a; letter-spacing:0.01em;"
            >
              Get a Free Quote
            </a>
            <a
              href={`tel:${phone.replace(/-/g, '')}`}
              class="inline-flex items-center justify-center gap-2 border border-white/20 text-white/80 font-medium text-sm px-7 py-3.5 rounded-[4px] hover:bg-white/8 transition-colors"
              aria-label={`Call us at ${phone}`}
              style="letter-spacing:0.01em;"
            >
              <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
              </svg>
              {phone}
            </a>
          </div>

          <!-- Trust row -->
          <div class="flex flex-wrap gap-x-5 gap-y-2">
            {['Free to Homeowners', 'Vetted Local Installers', 'No Obligation'].map(item => (
              <span class="flex items-center gap-2 text-sm text-white/55">
                <span class="w-4 h-4 rounded-[2px] flex items-center justify-center shrink-0" style="background:#f5e642;">
                  <svg class="w-2.5 h-2.5" fill="none" stroke="#1a1a1a" stroke-width="3" viewBox="0 0 12 12" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M1.5 6l3 3 6-6"/>
                  </svg>
                </span>
                {item}
              </span>
            ))}
          </div>
        </div>

        <!-- Right: Mascot — vertically centered in hero -->
        <div class="hidden lg:block relative self-center">
          <img
            src="/mascot-hero.png"
            alt="Generator Gators mascot — a gator in a hard hat holding a standby generator"
            width="500"
            height="480"
            loading="eager"
            class="w-full max-w-[500px] drop-shadow-2xl"
            style="display:block;"
          />
        </div>

      </div>
    </div>
  </section>

  <!-- STATS BAR -->
  <section class="bg-[#1a1a1a]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 divide-x divide-white/8">
        {[
          { num: '500+', label: 'Installs Facilitated' },
          { num: '24hr', label: 'Average Response Time' },
          { num: '100%', label: 'Free to Homeowners' },
          { num: '4',    label: 'Service Regions' },
        ].map(s => (
          <div class="flex flex-col items-center justify-center py-9 px-5 text-center">
            <span
              class="font-extrabold leading-none"
              style="font-size:2.6rem; color:#f5e642; letter-spacing:-0.02em;"
            >
              {s.num}
            </span>
            <span class="text-white/40 text-xs font-medium tracking-wider uppercase mt-2">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="bg-white py-24 px-4">
    <div class="max-w-7xl mx-auto">
      <div class="mb-14">
        <p class="text-xs font-semibold tracking-widest uppercase text-gray-400 mb-3">Simple Process</p>
        <h2
          class="font-extrabold text-[#1a1a1a]"
          style="font-size:clamp(1.75rem,3.5vw,2.5rem); line-height:1.2; letter-spacing:-0.02em;"
        >
          Get matched in three steps.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-[2px] bg-gray-150 rounded-[6px] overflow-hidden" style="background:#e5e7eb;">
        {[
          {
            num: '01',
            title: 'Tell Us About Your Home',
            desc: 'Fill out our quick form with your zip code and power needs. Takes under 60 seconds.',
          },
          {
            num: '02',
            title: 'Get Matched With a Pro',
            desc: 'We connect you with a vetted, licensed installer in your area — one who knows local codes, permits, and utility requirements.',
          },
          {
            num: '03',
            title: 'Receive Your Free Quote',
            desc: 'Your installer contacts you to schedule a site visit and provide a free, detailed installation quote. Zero obligation.',
          },
        ].map((step, i) => (
          <div class="bg-white px-9 pt-9 pb-10">
            <span
              class="block font-extrabold leading-none mb-6"
              style={`font-size:2.75rem; color:#f5e642; letter-spacing:-0.02em;`}
              aria-hidden="true"
            >
              {step.num}
            </span>
            <h3 class="font-bold text-[#1a1a1a] mb-3" style="font-size:1.05rem;">{step.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{step.desc}</p>
          </div>
        ))}
      </div>

      <div class="mt-9">
        <a
          href="#quote-form"
          class="inline-flex items-center gap-2 font-semibold text-sm px-7 py-3.5 rounded-[4px] transition-colors"
          style="background:#1a3a2a; color:#fff; letter-spacing:0.01em;"
        >
          Start My Free Quote
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ABOUT STANDBY GENERATORS -->
  <section class="bg-[#1a3a2a] py-24 px-4 text-white">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

        <div>
          <p class="text-xs font-semibold tracking-widest uppercase text-white/35 mb-3">What You're Getting</p>
          <h2
            class="font-extrabold text-white mb-6"
            style="font-size:clamp(1.75rem,3.5vw,2.5rem); line-height:1.2; letter-spacing:-0.02em;"
          >
            Whole Home Generator<br />Installation
          </h2>
          <p class="text-white/60 leading-relaxed mb-5 text-sm">
            A standby generator is permanently installed and turns on automatically when your utility power fails. It runs on natural gas or propane — no manual start, no refueling — and can power your entire home without any action from you.
          </p>
          <p class="text-white/60 leading-relaxed mb-8 text-sm">
            For homeowners in Long Island and NYC, where nor'easters and summer storms routinely cause multi-day outages, a whole-home standby generator is one of the most valuable investments you can make.
          </p>

          <ul class="space-y-3 mb-10">
            {[
              'Automatic activation — no manual start required',
              'Powers your entire home, not just select circuits',
              'Runs on natural gas or propane — no refueling',
              'Adds measurable resale value to your home',
              'Peace of mind throughout storm season',
            ].map(point => (
              <li class="flex items-start gap-3 text-white/75 text-sm">
                <span class="w-5 h-5 rounded-[2px] flex items-center justify-center shrink-0 mt-0.5" style="background:#f5e642;">
                  <svg class="w-3 h-3" fill="none" stroke="#1a1a1a" stroke-width="3" viewBox="0 0 12 12" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M1.5 6l3 3 6-6"/>
                  </svg>
                </span>
                {point}
              </li>
            ))}
          </ul>

          <a
            href="/whole-home-generator-installation"
            class="inline-flex items-center gap-2 font-semibold text-sm px-6 py-3 rounded-[4px] transition-colors"
            style="background:#f5e642; color:#1a1a1a; letter-spacing:0.01em;"
          >
            Learn About Generator Installation
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>

        <!-- Key numbers -->
        <div class="border border-white/10 rounded-[6px] overflow-hidden">
          <div class="px-8 py-5 border-b border-white/10">
            <p class="text-xs font-semibold tracking-widest uppercase text-white/35">Key Numbers</p>
          </div>
          <div class="divide-y divide-white/10">
            {[
              { stat: '72 hrs+', label: 'Average outage duration after major storms on Long Island' },
              { stat: '$7K–$20K', label: 'Typical installed cost for a whole-home standby generator' },
              { stat: '10 sec', label: 'Time for a standby generator to automatically activate' },
              { stat: '#1', label: 'Most requested home improvement after storm events in the Northeast' },
            ].map(item => (
              <div class="flex items-center gap-6 px-8 py-6">
                <span
                  class="font-extrabold shrink-0 w-28 leading-tight"
                  style="font-size:1.35rem; color:#f5e642; letter-spacing:-0.01em;"
                >
                  {item.stat}
                </span>
                <p class="text-white/55 text-sm leading-snug">{item.label}</p>
              </div>
            ))}
          </div>
          <div class="px-8 py-5 border-t border-white/10">
            <a
              href="/generator-installation-cost"
              class="inline-flex items-center gap-2 text-sm font-medium transition-colors"
              style="color:#f5e642;"
            >
              See detailed cost breakdown
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- AREAS WE SERVE -->
  <section class="bg-white py-24 px-4">
    <div class="max-w-7xl mx-auto">
      <div class="mb-14">
        <p class="text-xs font-semibold tracking-widest uppercase text-gray-400 mb-3">Coverage</p>
        <h2
          class="font-extrabold text-[#1a1a1a]"
          style="font-size:clamp(1.75rem,3.5vw,2.5rem); line-height:1.2; letter-spacing:-0.02em;"
        >
          Areas We Serve
        </h2>
      </div>

      <!-- Pixel-gap grid -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-[2px] rounded-[6px] overflow-hidden mb-8" style="background:#e5e7eb;">
        {[
          { name: 'Brooklyn, NY',   href: '/locations/brooklyn-ny',     sub: 'New York City' },
          { name: 'Queens, NY',     href: '/locations/queens-ny',        sub: 'New York City' },
          { name: 'Nassau County',  href: '/locations/nassau-county-ny', sub: 'Long Island' },
          { name: 'Suffolk County', href: '/locations/suffolk-county-ny',sub: 'Long Island' },
        ].map(area => (
          <a
            href={area.href}
            class="group bg-white hover:bg-[#1a3a2a] transition-colors duration-200 px-7 py-9 flex flex-col justify-between min-h-[160px]"
          >
            <div>
              <p class="text-xs font-semibold tracking-widest uppercase text-gray-400 group-hover:text-white/35 mb-2.5 transition-colors">{area.sub}</p>
              <h3
                class="font-bold text-[#1a1a1a] group-hover:text-white transition-colors leading-snug"
                style="font-size:1.15rem; letter-spacing:-0.01em;"
              >
                {area.name}
              </h3>
            </div>
            <span class="inline-flex items-center gap-1.5 text-xs font-medium mt-5 text-gray-400 group-hover:text-[#f5e642] transition-colors">
              View area
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </span>
          </a>
        ))}
      </div>

      <a
        href="/locations"
        class="inline-flex items-center gap-2 text-sm font-medium text-gray-400 hover:text-[#1a3a2a] transition-colors"
      >
        View all service areas
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- POWER OUTAGE PREPAREDNESS -->
  <section class="py-24 px-4" style="background:#f5e642;">
    <div class="max-w-7xl mx-auto">
      <div class="mb-14">
        <p class="text-xs font-semibold tracking-widest uppercase mb-3" style="color:rgba(26,26,26,0.45);">Why It Matters</p>
        <h2
          class="font-extrabold"
          style="font-size:clamp(1.75rem,3.5vw,2.5rem); line-height:1.2; letter-spacing:-0.02em; color:#1a1a1a;"
        >
          Power Outage Preparedness
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-[2px] rounded-[6px] overflow-hidden" style="background:#e8d800;">
        {[
          {
            title: 'Storm Season on Long Island',
            desc: "Long Island regularly faces nor'easters, tropical storms, and hurricanes that knock out power for days at a time. A standby generator means your household stays safe and comfortable regardless of what the weather brings.",
          },
          {
            title: 'Medical Needs & Safety',
            desc: 'For households with oxygen concentrators, CPAP machines, or refrigerated medications, reliable backup power is essential — not a luxury.',
          },
          {
            title: 'Home Protection',
            desc: 'Power outages lead to frozen pipes, basement flooding when sump pumps fail, and thousands in spoiled food. Standby power keeps your home protected around the clock.',
          },
          {
            title: 'Work From Home',
            desc: 'With more homeowners working remotely, a power outage means missed deadlines and lost income. Standby power keeps you connected and productive.',
          },
        ].map(item => (
          <div class="px-9 py-9" style="background:#f5e642;">
            <h3 class="font-bold mb-2.5" style="font-size:1rem; color:#1a1a1a; letter-spacing:-0.01em;">{item.title}</h3>
            <p class="text-sm leading-relaxed" style="color:rgba(26,26,26,0.6);">{item.desc}</p>
          </div>
        ))}
      </div>

      <div class="mt-10">
        <a
          href="#quote-form"
          class="inline-flex items-center gap-2 font-semibold text-sm px-7 py-3.5 rounded-[4px] transition-colors"
          style="background:#1a3a2a; color:#fff; letter-spacing:0.01em;"
        >
          Get Protected — Free Quote
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- QUOTE FORM -->
  <QuoteForm
    title="Get Your Free Generator Quote"
    subtitle="Fill out the form and we'll match you with a vetted local standby generator installer — usually within 24 hours."
  />

  <!-- TRUST ROW -->
  <section class="bg-white py-14 px-4 border-t border-gray-100">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-6">
        {[
          { label: 'Vetted Partners',  sub: 'Licensed & insured' },
          { label: 'Free Estimates',   sub: 'No obligation quotes' },
          { label: 'Local Experts',    sub: 'Serving your area' },
          { label: 'Fast Response',    sub: 'Quote within 24 hrs' },
        ].map(badge => (
          <div class="flex items-start gap-3">
            <span class="w-7 h-7 rounded-[3px] flex items-center justify-center shrink-0 mt-0.5" style="background:#f5e642;">
              <svg class="w-3.5 h-3.5" fill="none" stroke="#1a1a1a" stroke-width="2.5" viewBox="0 0 16 16" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2 8l4 4 8-8"/>
              </svg>
            </span>
            <div>
              <div class="font-semibold text-[#1a1a1a] text-sm leading-snug">{badge.label}</div>
              <div class="text-gray-400 text-xs mt-0.5">{badge.sub}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <FAQSection />

  <!-- MOBILE STICKY CTA -->
  <div class="lg:hidden fixed bottom-0 left-0 right-0 z-40 flex gap-[2px]" style="background:#1a1a1a;">
    <a
      href={`tel:${phone.replace(/-/g, '')}`}
      class="flex-1 flex items-center justify-center gap-2 font-semibold py-4 text-sm"
      style="background:#1a3a2a; color:#fff;"
      aria-label={`Call us at ${phone}`}
    >
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
        <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
      </svg>
      Call Now
    </a>
    <a
      href="#quote-form"
      class="flex-1 flex items-center justify-center font-semibold py-4 text-sm"
      style="background:#f5e642; color:#1a1a1a;"
    >
      Free Quote
    </a>
  </div>

</Layout>
