---
const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Generator Installation', href: '/whole-home-generator-installation' },
  { label: 'Installation Cost', href: '/generator-installation-cost' },
  { label: 'Locations', href: '/locations' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
];

const phone = '555-555-5555';
const currentPath = Astro.url.pathname;
---

<header class="bg-white border-b border-gray-200 sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20 md:h-24">

      <!-- Logo -->
      <a href="/" class="shrink-0">
        <img
          src="/logo-header.png"
          alt="Generator Gators"
          class="h-14 md:h-16 w-auto"
        />
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-7" aria-label="Main navigation">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`text-sm font-medium transition-colors ${
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'text-[#1a3a2a] font-semibold border-b-2 border-[#f5e642] pb-0.5'
                : 'text-gray-600 hover:text-[#1a3a2a]'
            }`}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- CTA Buttons -->
      <div class="hidden md:flex items-center gap-3">
        <a
          href={`tel:${phone.replace(/-/g, '')}`}
          class="flex items-center gap-1.5 text-[#1a3a2a] font-semibold text-sm hover:text-black transition-colors"
          aria-label={`Call us at ${phone}`}
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
          </svg>
          {phone}
        </a>
        <a
          href="/contact"
          class="bg-[#f5e642] hover:bg-yellow-300 text-[#1a1a1a] font-bold text-sm px-5 py-2.5 rounded-[4px] transition-colors"
        >
          Get Free Quote
        </a>
      </div>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 text-gray-600 hover:text-[#1a3a2a] transition-colors"
        aria-label="Toggle mobile menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="menu-open-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="menu-close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden border-t border-gray-200 bg-white"
    role="navigation"
    aria-label="Mobile navigation"
  >
    <div class="max-w-7xl mx-auto px-4 py-4 space-y-0.5">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="block px-3 py-3 text-base font-medium text-gray-700 hover:text-[#1a3a2a] hover:bg-gray-50 transition-colors"
        >
          {link.label}
        </a>
      ))}
      <div class="pt-4 border-t border-gray-100 space-y-3 mt-2">
        <a
          href={`tel:${phone.replace(/-/g, '')}`}
          class="flex items-center gap-2 px-3 py-3 text-base font-semibold text-[#1a3a2a]"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
          </svg>
          Call {phone}
        </a>
        <a
          href="/contact"
          class="block text-center bg-[#f5e642] hover:bg-yellow-300 text-[#1a1a1a] font-bold px-4 py-3.5 rounded-[4px] transition-colors"
        >
          Get Free Quote
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const openIcon = document.getElementById('menu-open-icon');
  const closeIcon = document.getElementById('menu-close-icon');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    openIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
